# Compass AI Backend — Environment Variables
# Copy to .env and fill in real values before running.

# Required: Backboard.io API key → https://app.backboard.io/settings
BACKBOARD_API_KEY=your_backboard_api_key_here

# Optional: Google Maps / Places (for live location data in search_locations tool)
# GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Optional: Google Sheets (for server-side /import/sheets fetch)
# GOOGLE_API_KEY=your_google_api_key_here
