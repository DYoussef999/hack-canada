# Compass AI Backend — Environment Variables
# Copy to .env and fill in real values before running.
# Run `GET /health` after startup to verify all APIs respond.

# ── Server ────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Google Gemini (REQUIRED for /sync and /optimize) ─────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Legacy alias also accepted:
# GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# ── FRED API (macro cross-reference) ─────────────────────────────────────────
# Get from: https://fred.stlouisfed.org/docs/api/api_key.html (free)
FRED_API_KEY=your_fred_api_key_here

# ── Mapbox (competitor density + transit proximity) ───────────────────────────
# Get from: https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=your_mapbox_public_token_here

# ── BestTime (foot traffic forecasts) ────────────────────────────────────────
# Get from: https://besttime.app/api (paid; /optimize degrades gracefully without it)
BESTTIME_API_KEY=your_besttime_private_api_key_here

# ── Square Sandbox (catalog data) ────────────────────────────────────────────
# Get from: https://developer.squareup.com/apps → Sandbox → Access token
SQUARE_SANDBOX_ACCESS_TOKEN=your_square_sandbox_token_here
SQUARE_ENVIRONMENT=sandbox

# ── Backboard.io (legacy agent layer) ────────────────────────────────────────
# Get from: https://app.backboard.io/settings
BACKBOARD_API_KEY=your_backboard_api_key_here

# ── Free public APIs (no keys required — enabled by default) ─────────────────
BOC_API_ENABLED=true
STATCAN_API_ENABLED=true
UPCITEMDB_ENABLED=true
